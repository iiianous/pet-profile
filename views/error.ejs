<%- include('partials/head') %>

<div class="flex min-h-screen items-center justify-center px-4 py-16">
  <div class="w-full max-w-2xl rounded-3xl border border-red-500/20 bg-slate-900/80 p-8 shadow-xl">
    <h1 class="text-3xl font-semibold text-red-300"><%= title %></h1>
    <p class="mt-4 text-slate-300"><%= message %></p>
    <% if (typeof stack !== 'undefined' && stack) { %>
      <pre class="mt-4 overflow-auto rounded-xl bg-slate-950 p-4 text-sm text-slate-400"><%= stack %></pre>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
