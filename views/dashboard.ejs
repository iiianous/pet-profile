<%- include('partials/head') %>

<div class="min-h-screen bg-[radial-gradient(circle_at_top,_rgba(34,197,94,0.18),_transparent_60%)] px-4 py-16">
  <div class="mx-auto max-w-5xl rounded-3xl border border-emerald-500/20 bg-slate-900/70 p-8 shadow-2xl shadow-emerald-500/10 backdrop-blur">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <div class="inline-flex rounded-full border border-emerald-400/30 bg-emerald-500/10 px-3 py-1 text-sm font-medium text-emerald-300">
          Protected dashboard
        </div>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight">Hello, <%= user.name %></h1>
        <p class="mt-2 text-lg text-slate-300">You are successfully signed in and can access this secure dashboard.</p>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 font-medium text-slate-100 transition hover:border-rose-400 hover:text-rose-300">Sign out</button>
      </form>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl border border-white/10 bg-slate-950/70 p-6">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-400">Account Info</p>
        <div class="mt-4 space-y-3 text-slate-300">
          <p><span class="text-slate-500">Name:</span> <%= user.name %></p>
          <p><span class="text-slate-500">Email:</span> <%= user.email %></p>
          <p><span class="text-slate-500">Member since:</span> <%= new Date(user.createdAt).toLocaleDateString() %></p>
        </div>
      </div>

      <div class="rounded-2xl border border-white/10 bg-slate-950/70 p-6">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-400">Security</p>
        <ul class="mt-4 space-y-2 text-slate-300">
          <li>• JWT is stored in an HttpOnly cookie</li>
          <li>• Passwords are hashed with bcrypt</li>
          <li>• Route protection blocks unauthenticated access</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
